# Banco de dados PostgreSQL (Neon - grátis)
# Obtido em: https://neon.tech
# Após criar projeto, vá em Connection Details
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Chave secreta para JWT (mude para algo único)
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao